{
  "name": "invoice-assistant",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev -- --host 127.0.0.1",
    "build": "npm --workspace apps/web run build",
    "preview": "npm run preview:web",
    "preview:web": "npm --workspace apps/web run preview -- --host 0.0.0.0",
    "test": "npm --workspace apps/web run test",
    "type-check": "npm --workspace apps/web run type-check"
  },
  "devDependencies": {
    "lefthook": "^1.13.6"
  }
}
